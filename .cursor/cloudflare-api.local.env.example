# Gitignored — Cloudflare API for setup-production-full.js
# Copy to cloudflare-api.local.env (never commit).
# Token needs Zone.DNS Edit on tsccoreknot.com
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Default Vercel CNAME target (confirm in Vercel → Domains):
CLOUDFLARE_VERCEL_CNAME=cname.vercel-dns.com
