# Gitignored — PostHog keys for setup scripts (never commit).
# Copy to posthog.local.env and fill values.
#
# Personal API key (phx_) — create at PostHog → Account settings → Personal API keys
# Scopes: project:read, project:write (for --provision)
POSTHOG_PERSONAL_API_KEY=phx_

# Shared ingest host (us or eu)
POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Production project token (phc_) — pushed to Vercel Production + Render
# Run: npm run production:setup:posthog -- --provision
VITE_POSTHOG_PROJECT_TOKEN=phc_

# Local dev project token (phc_) — written to client/.env only
VITE_POSTHOG_PROJECT_TOKEN_DEV=phc_

# Server-side capture (same as production phc_)
POSTHOG_PROJECT_API_KEY=phc_

# Optional — auto-filled by setup-posthog-production.js --provision
# VITE_POSTHOG_PROJECT_ID=12345
# VITE_POSTHOG_DASHBOARD_URL=https://us.posthog.com/project/12345
# VITE_POSTHOG_APP_URL=https://tsccoreknot.com
