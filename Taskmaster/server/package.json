{
  "name": "coreknot-server",
  "version": "1.0.8-beta.1",
  "description": "Enterprise Work Management API",
  "main": "server.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p ../tsconfig.json",
    "build": "cd ../client && npm install && npm run build",
    "start": "node server.js",
    "predev": "node scripts/freePort.js 5000 --wait",
    "dev": "nodemon server.js",
    "dev:stable": "node scripts/freePort.js 5000 --wait && node --watch server.js",
    "test": "node scripts/jestRun.cjs",
    "test:uploadthing": "node scripts/testUploadthingRoutes.js",
    "test:uploadthing:prod": "node scripts/testProductionUpload.js",
    "check:uploadthing-prod": "node scripts/checkProductionUploadthing.js",
    "sync-db": "node scripts/syncProdToLocal.js --yes",
    "sync-tenant-tsc": "node scripts/syncProdTenantToLocal.js --yes --slug=tsc",
    "sync-finance-to-prod": "node scripts/syncFinanceToProd.js",
    "sync-email-campaigns:dry-run": "node scripts/syncEmailCampaignsToProd.js --dry-run",
    "sync-email-campaigns:prod": "node scripts/syncEmailCampaignsToProd.js --yes",
    "import-finance": "node scripts/importInvoices.js --skip-ocr",
    "import-finance:fresh": "node scripts/importInvoices.js --fresh --skip-ocr",
    "backup:daily": "node scripts/runDailyBackup.js",
    "import:media-list": "node scripts/importMediaListFromSheet.js --prod --replace",
    "import:media-list:dry-run": "node scripts/importMediaListFromSheet.js --prod --dry-run",
    "seed:music-calendar": "node scripts/seedMusicContentCalendar.js --year=2026",
    "seed:music-calendar:prod": "node scripts/seedMusicContentCalendar.js --year=2026 --prod",
    "reconcile:datahub:prod": "node scripts/reconcileDataHub.js --prod --full",
    "seed:prod-content": "node scripts/seedProductionContent.js",
    "seed:daily-log-demo": "node scripts/seed-daily-log-timeline-demo.js",
    "sync:github-commits:dry-run": "node scripts/syncGithubCommitsToDailyLogs.js --dry-run --since=all",
    "sync:github-commits:prod": "node scripts/syncGithubCommitsToDailyLogs.js --prod --yes --since=all",
    "reset-weak-passwords": "node scripts/resetWeakUserPasswords.js",
    "reset-weak-passwords:local:apply": "node scripts/resetWeakUserPasswords.js --apply",
    "reset-weak-passwords:prod": "node scripts/resetWeakUserPasswords.js --prod",
    "reset-weak-passwords:prod:apply": "node scripts/resetWeakUserPasswords.js --prod --apply",
    "normalize:person-data": "node scripts/normalizePersonData.js --dry-run",
    "normalize:person-data:execute": "node scripts/normalizePersonData.js --execute",
    "repair:lead-phones": "node scripts/repairCorruptPhones.js",
    "qa:audit": "node scripts/qaAuditReport.js",
    "qa:suite3-static": "node scripts/runQaSuite3Static.js",
    "migrate:status": "migrate-mongo status -f migrate-mongo-config.js",
    "migrate:up": "migrate-mongo up -f migrate-mongo-config.js",
    "qa:cleanup": "node scripts/qaFullCleanup.js",
    "qa:cleanup:prod": "node scripts/qaFullCleanup.js --prod",
    "storage:audit": "node scripts/atlasStorageCleanup.js --dry-run",
    "storage:cleanup": "node scripts/atlasStorageCleanup.js --execute",
    "storage:cleanup:backups": "node scripts/atlasStorageCleanup.js --execute --only=backups --db=backups",
    "repair:phones": "node scripts/repairCorruptPhones.js --local",
    "repair:phones:prod": "node scripts/repairCorruptPhones.js --prod",
    "repair:phones:all": "node scripts/repairCorruptPhones.js --local && node scripts/repairCorruptPhones.js --prod",
    "purge:local-only-collections": "node scripts/purgeLocalOnlyCollections.js --execute",
    "purge:local-only-collections:dry-run": "node scripts/purgeLocalOnlyCollections.js --dry-run",
    "render:ops-fix": "node scripts/applyRenderOpsFixes.js",
    "render:ops-fix:deploy": "node scripts/applyRenderOpsFixes.js --deploy",
    "supabase:setup": "node scripts/supabaseSetup.js",
    "supabase:health": "node scripts/supabaseHealthCheck.js",
    "audit:data-topology": "node scripts/auditDataTopology.js",
    "audit:data-topology:purge-dry-run": "node scripts/auditDataTopology.js --purge-dry-run",
    "mongo:ensure-cold-ttl": "node scripts/ensureColdArchiveTtlIndexes.js",
    "supabase:backfill": "node scripts/supabaseBackfill.js",
    "supabase:migrate": "node scripts/supabaseFastMigrate.js --prod",
    "supabase:migrate:local": "node scripts/supabaseFastMigrate.js",
    "backup:verify-supabase": "node scripts/verifySupabaseBackup.js",
    "prepare:havells-data": "node scripts/prepareHavellsData.js",
    "prepare:havells-data:pull": "node scripts/prepareHavellsData.js --pull",
    "import:havells:dry-run": "node scripts/importHavellsToDataHub.js --prod",
    "import:havells:prod": "node scripts/importHavellsToDataHub.js --prod --execute",
    "verify:havells-datahub": "node scripts/verifyHavellsDataHub.js",
    "verify:havells-datahub:prod": "node scripts/verifyHavellsDataHub.js --prod",
    "sync:havells-hub-bulk:prod": "node scripts/bulkSyncHavellsHubInlets.js --prod",
    "rebuild:person-hub": "node scripts/rebuildPersonHub.js",
    "rebuild:person-hub:prod": "node scripts/rebuildPersonHub.js --prod",
    "sync:person-hub:prod": "node scripts/rebuildPersonHub.js --prod --sync-only",
    "export:datahub:db-minus-havells": "node scripts/exportDbMinusHavellsCsv.js --prod",
    "import:aisensy-campaign:dry-run": "node scripts/importAisensyCampaignCsv.js --prod",
    "import:aisensy-campaign:prod": "node scripts/importAisensyCampaignCsv.js --prod --execute",
    "sync:aisensy-catalog": "node scripts/syncAisensyCampaignCatalog.js",
    "sync:aisensy-catalog:prod": "node scripts/syncAisensyCampaignCatalog.js --prod --execute",
    "sync:aisensy-outcomes": "node scripts/syncAisensyCampaignOutcomes.js",
    "sync:aisensy-outcomes:prod": "node scripts/syncAisensyCampaignOutcomes.js --prod --execute"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@coreknot/contracts": "1.0.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.63.0",
    "@supabase/supabase-js": "^2.108.2",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cookie": "^0.7.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "geoip-lite": "^2.0.3",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "imap-simple": "^5.1.0",
    "ioredis": "^5.11.0",
    "ip-address": "^10.2.0",
    "ipaddr.js": "^2.4.0",
    "js-cookie": "^3.0.8",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.0",
    "juice": "^12.1.1",
    "mailparser": "^3.9.12",
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.4",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "node-ical": "^0.26.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "2.4.5",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "posthog-node": "^5.38.5",
    "resend": "^6.16.0",
    "socket.io": "^4.8.3",
    "svix": "^1.96.1",
    "tesseract.js": "^7.0.0",
    "uploadthing": "^7.7.4",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "migrate-mongo": "^14.0.7",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
