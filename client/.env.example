# Copy to client/.env for local development (gitignored)
# Full guide: docs/LOCAL_DEV_DATABASE.md

# Local API — required so axios/socket.io hit localhost:5000, not Render
VITE_API_URL=http://localhost:5000

# Optional feature flags
# VITE_MAIL_ENGINE_V2=true

# --- DO NOT put these in client/.env for local dev ---
# Production (set in Vercel Dashboard → Environment → Production only):
# VITE_API_URL=https://CoreKnot-jfw0.onrender.com
# VITE_GOOGLE_CLIENT_ID=...
# VITE_CLERK_PUBLISHABLE_KEY=...
