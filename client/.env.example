# Copy to client/.env for local development (gitignored)
# Full guide: docs/LOCAL_DEV_DATABASE.md
#
# Dev server also loads committed client/.env.development (localhost:5000).
# That overrides a wrong production URL in client/.env — still restart vite after edits.

# Local API — required so axios/socket.io hit localhost:5000, not Render
VITE_API_URL=http://localhost:5000

# Optional feature flags
# VITE_MAIL_ENGINE_V2=true

# Agentation annotate UI — enabled in committed client/.env.development only.
# Never add VITE_ENABLE_AGENTATION to Vercel or client/.env.production.
# Optional MCP sync when agentation-mcp server is running locally:
# VITE_AGENTATION_ENDPOINT=http://localhost:4747

# Optional — Render Dashboard log deep links (admin widgets / Admin Console)
# Service ID from Render Dashboard URL: dashboard.render.com/web/srv-XXXX/logs
# VITE_RENDER_SERVICE_ID_PRODUCTION=srv-...
# VITE_RENDER_SERVICE_ID_STAGING_API=srv-...
# VITE_RENDER_SERVICE_ID_STAGING_NEST=srv-...
# Or full URL overrides:
# VITE_RENDER_LOGS_PRODUCTION_URL=https://dashboard.render.com/web/srv-.../logs

# PostHog product analytics — capture only on production hosts (tsccoreknot.com, auth, landing)
# Override: VITE_POSTHOG_CAPTURE=true|false
# VITE_POSTHOG_PROJECT_TOKEN=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_PROJECT_ID=468825
# VITE_POSTHOG_APP_URL=https://us.posthog.com/project/468825

# Clerk auth (Vite reads VITE_*; NEXT_PUBLIC_* also supported in code)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# VITE_CLERK_DASHBOARD_URL=https://dashboard.clerk.com
# VITE_CLERK_DASHBOARD_APP_PATH=apps/app_xxxx
# Pin Clerk org for this deployment (must match server CLERK_ORGANIZATION_ID):
# VITE_CLERK_ORGANIZATION_ID=org_xxxx

# Org slug prefix routes (/:orgSlug/dashboard). Set false to use legacy flat paths.
# VITE_ORG_SLUG_ROUTES=true

# USD→INR uses live rate from GET /api/subscriptions/usd-inr-rate (Frankfurter).
# Dev override (server only): USD_INR_RATE_OVERRIDE in server/.env

# --- Vercel Preview (staging API + Supabase preview DB) ---
# Set in Vercel Dashboard → Environment → Preview only (not local .env):
# VITE_API_URL=https://<staging-api>.onrender.com
# RENDER_API_PROXY_URL=https://<staging-api>.onrender.com
# Clerk (required for /login and root redirect on preview — use pk_test_ for Preview):
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...  # optional alias (vite envPrefix)
# VITE_CLERK_ORGANIZATION_ID=org_...
# Omit both keys only on CI builds that must not call Clerk (app uses legacy session paths).
# See docs/PREVIEW_SUPABASE_CUTOVER.md and .cursor/production-hosts.local.json

# --- DO NOT put these in client/.env for local dev ---
# Production (set in Vercel Dashboard → Environment → Production only):
# VITE_API_URL=https://YOUR-PRODUCTION-API
# VITE_POSTHOG_PROJECT_TOKEN=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_APP_URL=https://tsccoreknot.com
# VITE_GOOGLE_CLIENT_ID=...
# VITE_CLERK_PUBLISHABLE_KEY=...

# --- Multi-site deploy (Vercel) ---
# Main app (tsccoreknot.com): default VITE_SITE_MODE=app (omit)
# Split deploy — set on main app Vercel project (Production):
# VITE_LANDING_URL=https://landing.tsccoreknot.com
# VITE_AUTH_URL=https://auth.tsccoreknot.com
# VITE_APP_URL=https://tsccoreknot.com
# Landing project: sites/landing — see docs/CLOUDFLARE_DNS.md
# Auth project: sites/auth

