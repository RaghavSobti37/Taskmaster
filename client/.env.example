# Copy to client/.env for local development (gitignored)
# Full guide: docs/LOCAL_DEV_DATABASE.md
#
# Dev server also loads committed client/.env.development (localhost:5000).
# That overrides a wrong production URL in client/.env — still restart vite after edits.

# Local API — required so axios/socket.io hit localhost:5000, not Render
VITE_API_URL=http://localhost:5000

# Optional feature flags
# VITE_MAIL_ENGINE_V2=true

# Agentation annotate UI — enabled in committed client/.env.development only.
# Never add VITE_ENABLE_AGENTATION to Vercel or client/.env.production.
# Optional MCP sync when agentation-mcp server is running locally:
# VITE_AGENTATION_ENDPOINT=http://localhost:4747

# USD→INR uses live rate from GET /api/subscriptions/usd-inr-rate (Frankfurter).
# Dev override (server only): USD_INR_RATE_OVERRIDE in server/.env

# --- Vercel Preview (staging API + Supabase preview DB) ---
# Set in Vercel Dashboard → Environment → Preview only (not local .env):
# VITE_API_URL=https://<staging-api>.onrender.com
# RENDER_API_PROXY_URL=https://<staging-api>.onrender.com
# See docs/PREVIEW_SUPABASE_CUTOVER.md and .cursor/production-hosts.local.json

# --- DO NOT put these in client/.env for local dev ---
# Production (set in Vercel Dashboard → Environment → Production only):
# VITE_API_URL=https://YOUR-PRODUCTION-API
# VITE_GOOGLE_CLIENT_ID=...
# VITE_CLERK_PUBLISHABLE_KEY=...

# --- Observability (set in Vercel Dashboard — Production / Preview) ---
# Sentry
# VITE_SENTRY_DSN=https://...@sentry.io/...
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=coreknot@1.0.2
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog RUM (browser)
# VITE_DD_APPLICATION_ID=
# VITE_DD_CLIENT_TOKEN=
# VITE_DD_SITE=datadoghq.com
# VITE_DD_ENV=production
# VITE_DD_SERVICE=coreknot-web
# VITE_DD_SESSION_SAMPLE_RATE=100
# VITE_DD_REPLAY_SAMPLE_RATE=0

# PostHog (browser) — project token from PostHog → Project settings
# VITE_POSTHOG_PROJECT_TOKEN=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# EU cloud: VITE_POSTHOG_HOST=https://eu.i.posthog.com

# --- Multi-site deploy (Vercel) ---
# Main app (tsccoreknot.com): default VITE_SITE_MODE=app (omit)
# Landing project (landing.tsccoreknot.com): vite build --mode landing
# VITE_LANDING_URL=https://landing.tsccoreknot.com
# VITE_APP_URL=https://tsccoreknot.com
# Auth routes use VITE_APP_URL (optional override: VITE_AUTH_URL)

