# Production — set in Vercel Dashboard (Production env), NOT in client/.env
# Real URL: .cursor/production-hosts.local.json → derived.viteApiUrl
# Bypasses Vercel /api rewrite (~4.5MB limit) for large campaign payloads
VITE_API_URL=https://YOUR-PRODUCTION-API

# Render log deep links (Vercel Production + Preview)
# VITE_RENDER_SERVICE_ID_PRODUCTION=srv-...
# VITE_RENDER_SERVICE_ID_STAGING_API=srv-...
# VITE_RENDER_SERVICE_ID_STAGING_NEST=srv-...
