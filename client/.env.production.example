# Production — set in Vercel Dashboard (Production env), NOT in client/.env
# Real URL: .cursor/production-hosts.local.json → derived.viteApiUrl
# Bypasses Vercel /api rewrite (~4.5MB limit) for large campaign payloads
VITE_API_URL=https://YOUR-PRODUCTION-API

# Split deploy — redirect app host marketing/auth to subdomains
VITE_LANDING_URL=https://landing.tsccoreknot.com
VITE_AUTH_URL=https://auth.tsccoreknot.com
VITE_APP_URL=https://tsccoreknot.com

# PostHog (browser) — project token from PostHog → Project settings
# Events proxy through /ph on your domain (see client/vercel.json.example)
# VITE_POSTHOG_PROJECT_TOKEN=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_APP_URL=https://tsccoreknot.com
# EU cloud: VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Render log deep links (Vercel Production + Preview)
# VITE_RENDER_SERVICE_ID_PRODUCTION=srv-...
# VITE_RENDER_SERVICE_ID_STAGING_API=srv-...
# VITE_RENDER_SERVICE_ID_STAGING_NEST=srv-...

# PostHog — set phc_ token on Vercel Production (secret)
# VITE_POSTHOG_PROJECT_TOKEN=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_PROJECT_ID=468825
# VITE_POSTHOG_APP_URL=https://us.posthog.com/project/468825
