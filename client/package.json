{
  "name": "CoreKnot-client",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "postinstall": "node scripts/generateVercelConfig.cjs",
    "prebuild": "node scripts/generateVercelConfig.cjs && node scripts/prebuildIcons.mjs",
    "build": "node scripts/generateVercelConfig.cjs && vite build",
    "prevercel-build": "node scripts/generateVercelConfig.cjs",
    "vercel-build": "npm run build",
    "vercel-build:landing": "node scripts/generateVercelConfig.cjs && node scripts/generate-pwa-icons.mjs && node scripts/generate-og-preview.mjs && vite build --mode landing",
    "vercel-build:auth": "node scripts/generateVercelConfig.cjs && node scripts/generate-pwa-icons.mjs && node scripts/generate-og-preview.mjs && vite build --mode auth && node scripts/verify-auth-build.mjs",
    "generate-icons": "node scripts/generate-pwa-icons.mjs",
    "lint": "eslint .",
    "test": "vitest run && node --test scripts/generateVercelConfig.test.cjs",
    "test:watch": "vitest",
    "preview": "vite preview",
    "lighthouse": "node scripts/lighthouse-audit.mjs",
    "lighthouse:public": "node scripts/lighthouse-audit.mjs --public-only",
    "lighthouse:ci": "node scripts/lighthouse-audit.mjs --public-only --min-a11y=90",
    "lighthouse:prod": "node scripts/lighthouse-audit.mjs --prod",
    "lighthouse:loop": "node scripts/lighthouse-loop.mjs",
    "lighthouse:loop:public": "node scripts/lighthouse-loop.mjs --public-only",
    "lighthouse:report": "node scripts/lighthouse-report-only.mjs"
  },
  "dependencies": {
    "@clerk/react": "^6.11.3",
    "@coreknot/contracts": "1.0.0",
    "@coreknot/design-tokens": "1.0.0",
    "@coreknot/local-database": "1.0.0",
    "@coreknot/sync-client": "1.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@number-flow/react": "^0.6.1",
    "@posthog/react": "^1.10.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.4",
    "@types/papaparse": "^5.5.2",
    "@uploadthing/react": "^7.3.3",
    "@vercel/analytics": "^2.0.1",
    "@visx/curve": "^4.0.1-alpha.0",
    "@visx/event": "^4.0.1-alpha.0",
    "@visx/gradient": "^4.0.1-alpha.0",
    "@visx/grid": "^4.0.1-alpha.0",
    "@visx/pattern": "^4.0.1-alpha.0",
    "@visx/responsive": "^4.0.1-alpha.0",
    "@visx/scale": "^4.0.1-alpha.0",
    "@visx/shape": "^4.0.1-alpha.0",
    "@xyflow/react": "^12.11.1",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "date-fns": "^4.4.0",
    "effect": "^3.21.3",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "opossum": "^10.0.0",
    "papaparse": "^5.5.4",
    "posthog-js": "^1.393.4",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^6.0.2",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "agentation": "^3.0.2",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "png-to-ico": "^3.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.35.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.62.2",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
