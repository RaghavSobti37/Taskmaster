{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://taskmaster-jfw0.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://taskmaster-jfw0.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "HUSKY=0 node scripts/generateVercelConfig.cjs && cd .. && rm -rf node_modules client/node_modules && npx --yes npm@11 install --legacy-peer-deps -w CoreKnot-client",
  "env": {
    "VERCEL_FORCE_NO_BUILD_CACHE": "1"
  }
}
