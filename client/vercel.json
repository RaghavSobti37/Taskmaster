{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://taskmaster-jfw0.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://taskmaster-jfw0.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "HUSKY=0 node scripts/generateVercelConfig.cjs && rm -rf node_modules ../node_modules && npm install --legacy-peer-deps"
}
