{
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/about",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/contact",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/wp-admin/:path*",
      "destination": "/404",
      "statusCode": 404
    },
    {
      "source": "/wp-login.php",
      "destination": "/404",
      "statusCode": 404
    },
    {
      "source": "/xmlrpc.php",
      "destination": "/404",
      "statusCode": 404
    },
    {
      "source": "/.env",
      "destination": "/404",
      "statusCode": 404
    }
  ],
  "rewrites": [
    {
      "source": "/api/attendance",
      "destination": "https://coreknot-nest-staging.onrender.com/api/attendance"
    },
    {
      "source": "/api/attendance/:path*",
      "destination": "https://coreknot-nest-staging.onrender.com/api/attendance/:path*"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://taskmaster-jfw0.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://taskmaster-jfw0.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api/)(?!.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "HUSKY=0 node scripts/generateVercelConfig.cjs && cd .. && rm -rf node_modules client/node_modules && npx --yes npm@11 install --legacy-peer-deps --include=optional",
  "env": {
    "VERCEL_FORCE_NO_BUILD_CACHE": "1"
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
