{
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/about",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/contact",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/wp-admin/:path*",
      "destination": "/404",
      "statusCode": 404
    },
    {
      "source": "/wp-login.php",
      "destination": "/404",
      "statusCode": 404
    },
    {
      "source": "/xmlrpc.php",
      "destination": "/404",
      "statusCode": 404
    },
    {
      "source": "/.env",
      "destination": "/404",
      "statusCode": 404
    }
  ],
  "rewrites": [
    {
      "source": "/api/(?!clerk-proxy)(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/socket.io/$1"
    },
    {
      "source": "/__clerk/:path*",
      "destination": "/api/clerk-proxy/:path*"
    },
    {
      "source": "/((?!api/)(?!ph/)(?!__clerk/)(?!.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "HUSKY=0 node scripts/generateVercelConfig.cjs && cd .. && node scripts/vercelInstall.js",
  "env": {
    "VERCEL_FORCE_NO_BUILD_CACHE": "1"
  }
}
