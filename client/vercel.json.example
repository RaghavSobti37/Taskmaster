{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "VERCEL_FORCE_NO_BUILD_CACHE=1 HUSKY=0 node scripts/generateVercelConfig.cjs && rm -rf node_modules && npm install --legacy-peer-deps"
}
