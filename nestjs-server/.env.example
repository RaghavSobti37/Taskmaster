# NestJS sandbox — copy to .env and fill in values (never commit .env)

PORT=5001

# PostgreSQL target for Prisma / Phase 3 ETL (NOT MongoDB)
# Local: Docker (npm run db:setup) — do NOT use Supabase cloud for local dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coreknot
# Preview QA only (gitignored .env.preview): Supabase preview project URL
# Prod cutover only (Render env): Supabase prod project URL

# Mongo source — ETL reads server/.env first; override here if needed
# MONGODB_URI=mongodb://localhost:27017/taskmaster_local

# Auth — must match Express JWT_SECRET for shared sessions
JWT_SECRET=your-jwt-secret-here

# Redis / Render Key Value (required for tracking + webhook processors)
REDIS_URL=redis://localhost:6379

# Mail tracking — must match Express locked config (see docs/EMAIL_ENGINE_LOCKED.md)
TRACKING_BASE_URL=https://YOUR-PRODUCTION-API
FRONTEND_URL=http://localhost:5173
RESEND_WEBHOOK_SECRET=
