{
  "name": "@coreknot/nestjs-server",
  "version": "0.1.0",
  "private": true,
  "description": "CoreKnot NestJS API — Phase 2 infrastructure",
  "scripts": {
    "build": "npx --yes prisma@6.11.1 generate && npx --yes @nestjs/cli@11.0.23 build",
    "start": "node dist/main.js",
    "start:dev": "node ../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node dist/main.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "npx --yes prisma@6.11.1 db push --accept-data-loss",
    "db:setup": "docker compose up -d --wait && npm run prisma:generate && npm run db:push",
    "prisma:generate": "npx --yes prisma@6.11.1 generate",
    "prisma:validate": "prisma validate",
    "etl:prisma:generate": "npx --yes prisma@6.11.1 generate --schema=prisma/etl/schema.prisma",
    "etl:prisma:push": "npx --yes prisma@6.11.1 db push --schema=prisma/etl/schema.prisma",
    "etl:mongo-to-postgres": "npm run etl:prisma:generate && tsx scripts/etl/mongo-to-postgres.ts",
    "etl:local-operational": "npm run prisma:generate && tsx scripts/etl/mongo-to-postgres.ts --tier=1 && tsx scripts/etl/mongo-to-postgres.ts --tier=2 && tsx scripts/etl/mongo-to-postgres.ts --tier=3 --exclude=leads,exlybookings",
    "etl:preview-from-hosts": "node scripts/run-preview-etl.js",
    "etl:prod-cutover-from-hosts": "node scripts/run-prod-cutover-etl.js",
    "etl:preview-full": "npm run prisma:generate && tsx scripts/etl/mongo-to-postgres.ts --tier=1 && tsx scripts/etl/mongo-to-postgres.ts --tier=2 && tsx scripts/etl/mongo-to-postgres.ts --tier=3 && tsx scripts/etl/mongo-to-postgres.ts --tier=4",
    "etl:validate-counts": "tsx scripts/etl/validate-counts.ts",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@coreknot/contracts": "*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.26",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.79.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^9.7.2",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "svix": "^1.96.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.26",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
