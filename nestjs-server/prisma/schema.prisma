  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([personId])
  @@index([email, phone, offeringId, bookedOn])
}

/// Mongo: newslettersubscribers
model NewsletterSubscriber {
  id                String   @id
  tenantId          String
  personId          String?
  name              String
  nameKey           String?
  email             String?
  phone             String?
  city              String?
  emailStatus       String   @default("Pending")
  subscribedAt      DateTime @default(now())
  source            String?
  unsubscribed      Boolean  @default(false)
  unsubscribeReason String?
  importId          String?
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([personId])
  @@index([email])
}

/// Mongo: artists
model Artist {
  id           String   @id
  tenantId     String
  name         String
  bio          String?
  profileImage String?
  website      String?
  socials      Json     @default("{}")
  events       Json     @default("[]")
  discography  Json     @default("[]")
  teamUserIds  String[] @default([])
  createdAt    DateTime @default(now())

  metrics     ArtistMetrics?
  auth        ArtistAuth?
  connections ArtistConnection[]

  @@index([tenantId])
}

/// Mongo: artistmetrics
model ArtistMetrics {
  id               String   @id
  tenantId         String
  artistId         String   @unique
  analytics        Json     @default("{}")
  trackedVideos    Json     @default("[]")
  history          Json     @default("[]")
  analyticsHistory Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Mongo: artistauths
model ArtistAuth {
  id               String   @id
  tenantId         String
  artistId         String   @unique
  oauthCredentials Json     @default("{}")
  isSynced         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Mongo: artistconnections
model ArtistConnection {
  id           String   @id
  tenantId     String
  artistId     String
  provider     String
  externalId   String?
  displayName  String?
  accessToken  String?
  refreshToken String?
  metadata     Json     @default("{}")
  connectedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([artistId])
}

/// Mongo: crmstatsnapshots
model CRMStatSnapshot {
  id        String   @id
  tenantId  String
  repId     String?
  metrics   Json     @default("{}")
  updatedAt DateTime @default(now())

  @@index([tenantId])
  @@index([repId])
}
