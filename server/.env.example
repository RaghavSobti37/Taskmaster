# Server environment variables - copy to server/.env and fill in secrets

# Local vs prod DB guide: docs/LOCAL_DEV_DATABASE.md

PORT=5000



# ============ DATABASE ============

# Local development — must differ from production DB name in URI path

MONGODB_URI=mongodb://localhost:27017/taskmaster_local

# Or Atlas: mongodb+srv://REDACTED:REDACTED@REDACTED.example.com/



# Production — used when NODE_ENV=production (Render API)

MONGODB_URI_PROD=mongodb+srv://REDACTED:REDACTED@REDACTED.example.com/



# Optional: explicit DB names for sync scripts (defaults below)

MONGODB_DB_LOCAL=taskmaster_local

MONGODB_DB_PROD=taskmaster_production



# Vercel Preview — set via Vercel dashboard env vars, not here

# VERCEL_ENV=preview → uses MONGODB_URI (taskmaster_local)

# VERCEL_ENV=production on API host → uses MONGODB_URI_PROD



# Prod → local sync mode default (full | operational). Operational skips CRM/Data Hub collections.
# SYNC_MODE=operational
# After operational sync, keep reconcile off locally:
DATA_HUB_RECONCILE_ENABLED=false

# Mail tracking from localhost: opt-in only — affects ENTIRE server DB connection when true
# When true, npm run dev connects to MONGODB_URI_PROD (production), not MONGODB_URI.
# Leave false for normal local development. Use TRACKING_BASE_URL for open/click pixels instead.
MAIL_USE_PROD_DB=false

# Log localhost office-IP bypass for attendance work-mode hint (dev only)
ATTENDANCE_DEBUG=false

# Lighthouse QA (optional): defaults to FRONTEND_URL on Render/production, localhost:4173 locally
# LH_BASE_URL=https://tsccoreknot.com
# LH_API_URL=https://YOUR-RENDER-SERVICE.onrender.com
# QA_PROBE_EMAIL_DOMAIN=theshakticollective.in



# Allow dev server to connect to a production-named DB (discouraged)

# ALLOW_PROD_DB_IN_DEV=false



# ============ AUTHENTICATION & SECURITY ============

JWT_SECRET=your_secure_secret_here
# 64-char hex — openssl rand -hex 32. Required on Render for OAuth/API token encryption.
ENCRYPTION_KEY=
JWT_EXPIRES_IN=7d
# Sliding inactivity window (JWT_EXPIRES_IN). Hard re-login cap from first login:
JWT_ABSOLUTE_MAX_DAYS=30
# Min minutes between Set-Cookie refreshes on activity (reduces mobile cookie churn):
JWT_REFRESH_MINUTES=60
# Override local dev default password (shared/defaultPassword.js fallback: 1Million#)
DEFAULT_SEED_PASSWORD=1Million#
NODE_ENV=development

# Production signup restrictions
ADMIN_EMAIL=admin@yourcompany.com
ALLOWED_DOMAIN=yourcompany.com
# REGISTRATION_DISABLED=true

# CRM monthly targets — prefer TSC Academy / TSC Films project Goals → CRM digest settings in CoreKnot
# Legacy env fallback when project goals unset (Academy only):
# CRM_DIGEST_MONTHLY_TARGET_LAKHS=10
# CRM_DIGEST_PLAN_VALUES={"One-Time":50000,"3 Mo":45000,"6 Mo":85000,"9 Mo":120000}

# Comma-separated extra allowed browser origins (production API CORS)
# CORS_ALLOWED_ORIGINS=https://coreknot.app,https://www.coreknot.app
# Allow any *.vercel.app preview origin in production (default: true)
# CORS_ALLOW_VERCEL_PREVIEWS=false

# FRONTEND_URL=https://coreknot.app



# ============ OFFICE & ATTENDANCE ============

# Comma-separated IPs that count as in-office (IPv4 office egress + IPv6 if applicable + localhost for dev).
# Code merges OFFICE_PUBLIC_IP and OFFICE_IP_WHITELIST — set at least one on Render.

OFFICE_PUBLIC_IP=49.36.41.166,49.36.41.118
OFFICE_IP_WHITELIST=49.36.41.166,49.36.41.118,127.0.0.1,::1,::ffff:127.0.0.1



# ============ WEB PUSH NOTIFICATIONS ============

# Desktop notifications when ERP tab is closed (localhost works without HTTPS)

# Generate once: npx web-push generate-vapid-keys

# Set the same keys on Render/production; restart server after adding them.

VAPID_PUBLIC_KEY=

VAPID_PRIVATE_KEY=

VAPID_SUBJECT=mailto:redacted@example.com



# ============ EXTERNAL APIs ============

# UploadThing — required for finance document uploads (/api/finance/upload-many)
# UPLOADTHING_TOKEN and UPLOADTHING_SECRET apiKey MUST match or ingest returns 400 Invalid signature.
# Run: node server/scripts/syncUploadthingToken.js (local) after rotating keys.
# UPLOADTHING_TOKEN=base64-json-from-uploadthing-dashboard
# UPLOADTHING_SECRET=sk_live_... (must match apiKey inside TOKEN)

HOLYSHEET_API_KEY=your_holysheet_api_key
# Artist Path questionnaire sheet (HolySheet API key for that linked spreadsheet)
HOLYSHEET_ARTIST_PATH_API_KEY=your_artist_path_holysheet_api_key
# Optional tab name when spreadsheet has multiple sheets (default: first sheet)
# HOLYSHEET_ARTIST_PATH_SHEET=Sheet1
# Booked calls: website → POST /api/webhooks/book-call (see docs/BOOKED_CALLS_CRM_DIRECT.md)
BOOK_CALL_WEBHOOK_SECRET=shared-with-tsc-website
# Optional: explicit tenant for inbound webhooks (defaults to oldest active tenant)
WEBHOOK_TENANT_ID=
# Optional explicit user id override (single rep — prefer round-robin via sales department)
# BOOKED_CALL_SALES_REP_ID=
# Website → POST /api/webhooks/artist-path (secret header or HMAC)
ARTIST_PATH_WEBHOOK_SECRET=shared-with-tsc-website
# Website → POST /api/webhooks/newsletter (X-Webhook-Secret only)
NEWSLETTER_WEBHOOK_SECRET=shared-with-tsc-website
# Website → POST /api/webhooks/masterclass-review (X-Webhook-Secret only)
MASTERCLASS_REVIEW_WEBHOOK_SECRET=shared-with-tsc-website
# Optional AiSensy campaign for artist-path confirmation WhatsApp
# AISENSY_ARTIST_PATH_CAMPAIGN=Confirmation TSC

EXLY_API_KEY=your_exly_api_key

# Public API base — used for OAuth callbacks when localhost env vars are set (Render)
# SERVER_URL=https://YOUR-PRODUCTION-API
# APP_BASE_URL=https://YOUR-PRODUCTION-API

# Google OAuth (staff login + Calendar/Drive)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://YOUR-PRODUCTION-API/api/auth/google/callback

# YouTube OAuth (artist analytics — separate GCP OAuth client recommended)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_OAUTH_REDIRECT_URI=https://YOUR-PRODUCTION-API/api/artists/auth/callback/youtube
# YOUTUBE_REDIRECT_URI_PROD=https://YOUR-PRODUCTION-API/api/artists/auth/callback/youtube
# YOUTUBE_API_KEY=

# Meta / Instagram (artist analytics)
# META_APP_ID=
# META_APP_SECRET=
# META_VERIFY_TOKEN=your_random_verify_string
# META_WEBHOOK_VERIFY_TOKEN=          # optional alias for META_VERIFY_TOKEN
# META_DEFAULT_PAGE_ID=               # optional fallback
# META_DEFAULT_IG_ID=                 # optional fallback
# META_USER_TOKEN=                    # dev fallback only — remove after App Review

# Frontend origin for Meta OAuth redirect (Vercel)
# CLIENT_URL=https://tsccoreknot.com
# FRONTEND_URL=https://tsccoreknot.com

# Spotify artist OAuth
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_OAUTH_REDIRECT_URI=https://YOUR-PRODUCTION-API/api/artists/auth/callback/spotify

# Google Service Account (Sheets webhooks — server-to-server, not user OAuth)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=tsc-newsletter@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEET_ID=

# Full verification guide: docs/GOOGLE_META_APP_VERIFICATION.md
# Pre-flight check (admin): GET /api/integrations/oauth-readiness

YOUTUBE_API_KEY=your_youtube_api_key



# ============ WEBHOOK SECRETS ============
# HMAC: X-Webhook-Signature: sha256=<hmac-sha256-hex of raw JSON body>
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# EXLY_WEBHOOK_SECRET=

# Artist enquiry form — required in production (plain header X-Webhook-Secret)
ARTIST_ENQUIRY_WEBHOOK_SECRET=shared-with-tsc-website

# Meta/Instagram webhook signature verification (required in production)
# META_APP_SECRET=
# META_VERIFY_TOKEN=

# ============ ARTIST ENQUIRY WEBHOOK (public /query form) ============

# Optional JSON map: lowercase artist label → project name (ALL CAPS storage)

# ARTIST_ENQUIRY_PROJECT_MAP={"yugm":"YUGM","harshad & duhita":"HARSHAD DUHITA"}

# Fallback project name when artist label does not match

# ARTIST_ENQUIRY_FALLBACK_PROJECT_NAME=YUGM

# Songstats enterprise API (no fallback in code — must be set for artist stats)
# SONGSTATS_API_KEY=



# ============ BACKUP CONFIGURATION ============

# Daily production backup (Render cron — 12:01 AM IST / 18:31 UTC)

# Backups read ONLY from MONGODB_URI_PROD — never from local MONGODB_URI

BACKUP_ENABLED=true

BACKUP_RETENTION_COUNT=2

MONGODB_BACKUP_DB=taskmaster_backups

BACKUP_NOTIFY_EMAIL=

BACKUP_FROM_EMAIL=noreply@theshakticollective.in

# Uses ADMIN_EMAIL when BACKUP_NOTIFY_EMAIL is empty

# BACKUP_FROM_EMAIL must use a Resend-verified domain (not sandbox@taskmaster.io)



# Optional: force USD→INR rate for local testing (skips live Frankfurter API)

# USD_INR_RATE_OVERRIDE=85



# ============ SUPABASE SECONDARY STORE (optional) ============
# Offloads backups, logs/audits, mail rollups, CRM snapshots from Mongo.
# Mongo remains primary until you explicitly approve Mongo purge.
# SUPABASE_SECONDARY_ENABLED=true
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_SECRET_KEY=alias for service role (same value)
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres  # local/scripts only (IPv6)
# SUPABASE_PG_MODE=rest   # auto on Render — use PostgREST over HTTPS (IPv4)
# Session pooler (optional if IPv4 direct pg needed): aws-0-[region].pooler.supabase.com:5432
# SUPABASE_BACKUP_BUCKET=taskmaster-backups
# Where production snapshots go when widget/cron runs backup (default: supabase when configured)
# BACKUP_DESTINATION=supabase
# BACKUP_DESTINATION=mongo
# BACKUP_DESTINATION=both
# LOG_LEVEL=info                 # local default; use warn on Render production
# Setup: npm run supabase:setup && npm run supabase:backfill && npm run supabase:health
# Audit: npm run audit:data-topology
# Cold TTL: npm run mongo:ensure-cold-ttl



# ============ LOCAL-FIRST SYNC (Express → Nest token proxy) ============
# Production Express proxies POST /api/v1/sync/token to Nest when set.
# Attendance stays on Express; only sync token uses Nest.
# NEST_SYNC_URL=https://YOUR-NEST-STAGING-HOST

# ============ LOGGING (stdout → Render log store) ============
# LOG_LEVEL=warn          # production default on Render
# LOG_LEVEL=info          # staging / local
# SERVICE_NAME=coreknot-api

