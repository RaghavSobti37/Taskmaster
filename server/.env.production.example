# Production OAuth / integration env — copy values to Render Dashboard (CoreKnot API service)
# Do NOT commit real secrets. See docs/GOOGLE_META_APP_VERIFICATION.md

NODE_ENV=production
SERVER_URL=https://CoreKnot-jfw0.onrender.com
APP_BASE_URL=https://CoreKnot-jfw0.onrender.com
TRACKING_BASE_URL=https://CoreKnot-jfw0.onrender.com

FRONTEND_URL=https://tsccoreknot.com
CLIENT_URL=https://tsccoreknot.com

ALLOWED_DOMAIN=theshakticollective.in
ADMIN_EMAIL=REDACTED_ADMIN@example.com

# Google staff login (consider Internal OAuth user type in GCP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://CoreKnot-jfw0.onrender.com/api/auth/google/callback

# YouTube artist analytics (External OAuth — requires Google verification)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=https://CoreKnot-jfw0.onrender.com/api/artists/auth/callback/youtube
YOUTUBE_REDIRECT_URI_PROD=https://CoreKnot-jfw0.onrender.com/api/artists/auth/callback/youtube
YOUTUBE_API_KEY=

# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
# Do not rely on META_USER_TOKEN in production after App Review

# Meta Dashboard URLs to register:
# OAuth redirect:  https://tsccoreknot.com/oauth/meta/callback
# Webhook:         https://CoreKnot-jfw0.onrender.com/api/webhooks/instagram
# Data deletion:   https://CoreKnot-jfw0.onrender.com/api/webhooks/meta-data-deletion
