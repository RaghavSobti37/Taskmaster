{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://taskmaster-jfw0.onrender.com/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "node ../scripts/generateVercelConfig.js && npm install"
}
