{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "env": {
    "preview": {
      "MONGODB_URI": "@local-mongodb-uri",
      "DATABASE_ENVIRONMENT": "preview",
      "VITE_API_URL": "https://YOUR-PRODUCTION-API.onrender.com",
      "RENDER_API_PROXY_URL": "https://YOUR-PRODUCTION-API.onrender.com"
    },
    "production": {
      "MONGODB_URI": "@prod-mongodb-uri",
      "DATABASE_ENVIRONMENT": "production"
    }
  }
}
