{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "preview": {
      "MONGODB_URI": "@local-mongodb-uri",
      "DATABASE_ENVIRONMENT": "preview",
      "VITE_API_URL": "https://coreknot-api-staging.onrender.com",
      "RENDER_API_PROXY_URL": "https://coreknot-api-staging.onrender.com"
    },
    "production": {
      "MONGODB_URI": "@prod-mongodb-uri",
      "DATABASE_ENVIRONMENT": "production"
    }
  }
}
